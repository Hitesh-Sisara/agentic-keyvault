{
  "name": "@agentic-keyvault/worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "test": "vitest --run",
    "test:watch": "vitest",
    "db:migrate:local": "wrangler d1 migrations apply agentic_keyvault --local",
    "db:migrate:remote": "wrangler d1 migrations apply agentic_keyvault --remote"
  },
  "dependencies": {
    "hono": "^4.6.14"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.5.40",
    "@cloudflare/workers-types": "^4.20241127.0",
    "fast-check": "^3.23.1",
    "typescript": "^5.7.2",
    "vitest": "2.1.8",
    "wrangler": "^4.81.1"
  }
}
